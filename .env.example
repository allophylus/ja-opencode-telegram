# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Your Telegram user ID (get from @userinfobot)
TELEGRAM_ALLOWED_USER_IDS=your_telegram_id
# OpenCode server URL
OPENCODE_URL=http://localhost:4096
# Optional: proxy URL for IPv4 workaround
TELEGRAM_PROXY_URL=http://localhost:8091

# Honcho memory integration (for opencode plugin)
HONCHO_BASE_URL=http://localhost:8000
HONCHO_WORKSPACE_ID=your_workspace_id
HONCHO_OBSERVED_PEER_ID=your_telegram_id
HONCHO_OBSERVER_PEER_ID=agent-main
