# Telegram Bot Token — get one from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs allowed to control OpenCode
TELEGRAM_ALLOWED_USER_IDS=your_telegram_user_id

# (Optional) Pre-set chat ID — auto-discovered on first message
# TELEGRAM_CHAT_ID=

# Models are loaded dynamically from `opencode models` at runtime
