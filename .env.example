# Telegram Bot Token — get from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs (get from @userinfobot)
TELEGRAM_ALLOWED_USER_IDS=your_telegram_id

# Optional: OpenCode server URL (default: http://localhost:4096)
# OPENCODE_URL=http://localhost:4096

# Files sent via Telegram are saved to ~/.opencode-attachments/
