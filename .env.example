# ── Bot config ──────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Your Telegram user ID (get from @userinfobot)
TELEGRAM_ALLOWED_USER_IDS=your_telegram_id
# OpenCode server URL
OPENCODE_API_URL=http://localhost:4096
# Force IPv4 (fixes Telegram connectivity on some VMs)
TELEGRAM_FORCE_IPV4=true

# ── Model selection ──────────────────────────────────────
# OpenCode reads these env vars as fallback model config.
# The actual model is set at runtime via /model command.
OPENCODE_MODEL_PROVIDER=deepseek
OPENCODE_MODEL_ID=deepseek-v4-flash
# API key for the provider above
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ── Honcho memory integration ────────────────────────────
# (for the opencode honcho plugin)
HONCHO_BASE_URL=http://localhost:8000
HONCHO_WORKSPACE_ID=your_workspace_id
HONCHO_OBSERVED_PEER_ID=your_telegram_id
HONCHO_OBSERVER_PEER_ID=agent-main

# ── Optional: proxy URL for IPv4 workaround ──────────────
# TELEGRAM_PROXY_URL=http://localhost:8091
